enum DiligenceJobStatus {
    QUEUED
    RUNNING
    WAITING_INPUT
    COMPLETED
    FAILED
    CANCELED
}

enum DiligenceStageName {
    DOCUMENT_EXTRACTION
    DOCUMENT_CLASSIFICATION
    EVIDENCE_INDEXING
    ENTITY_EXTRACTION
    CLAIM_EXTRACTION
    CORROBORATION
    Q1_IDENTITY_AND_OWNERSHIP
    Q2_PRODUCT_AND_TECHNOLOGY
    Q3_MARKET_AND_TRACTION
    Q4_EXECUTION_CAPABILITY
    Q5_BUSINESS_MODEL_VIABILITY
    Q6_RISK_ANALYSIS
    Q8_FAILURE_MODES_AND_FRAGILITY
    OPEN_QUESTIONS
    EXECUTIVE_SUMMARY
    FINAL_REPORT
}

enum DiligenceStageStatus {
    PENDING
    RUNNING
    COMPLETED
    FAILED
    SKIPPED
}

enum DiligenceArtifactType {
    ORIGINAL_DOCUMENT
    EXTRACTED_TEXT
    OCR_OUTPUT
    DOCUMENT_CHUNK
    EMBEDDING_SNAPSHOT
    INTERMEDIATE_JSON
    MODEL_TRACE
    EVIDENCE_MAP
    GENERATED_REPORT
    EXPORT_BUNDLE
}

enum DiligenceStorageProvider {
    VERCEL_BLOB
    DATABASE
    JSON_COLUMN
    VECTOR_DATABASE
    OBJECT_STORAGE
    TEMPORARY_STORAGE
}

enum DiligenceFindingType {
    RISK
    OPPORTUNITY
    WARNING
    OBSERVATION
}

enum DiligenceClaimStatus {
    SUPPORTED
    CONTRADICTED
    INCONCLUSIVE
}

enum DiligenceCoreQuestion {
    Q1_IDENTITY
    Q2_PRODUCT
    Q3_MARKET
    Q4_EXECUTION
    Q5_BUSINESS_MODEL
    Q6_RISKS
    Q7_EVIDENCE
    Q8_FAILURE_MODES
}

model DiligenceJob {
    id                String             @id @default(cuid())
    projectId         String
    userId            String
    userApiKeyId      String?
    selectedProvider  ApiKeyProvider
    selectedModel     String
    fallbackProviders Json?
    status            DiligenceJobStatus @default(QUEUED)
    currentStage      DiligenceStageName?
    progressPercent   Int                @default(0)
    attemptCount      Int                @default(0)
    inputDocumentCount Int               @default(0)
    tokenUsageTotal   Int                @default(0)
    estimatedCostUsd  Float?
    priority          Int                @default(0)
    workflowRunId     String?
    startedAt         DateTime?
    completedAt       DateTime?
    lastHeartbeatAt   DateTime?
    errorMessage      String?
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userApiKey UserApiKey? @relation(fields: [userApiKeyId], references: [id], onDelete: SetNull)

    stageRuns DiligenceStageRun[]
    artifacts DiligenceArtifact[]
    findings DiligenceFinding[]
    claims DiligenceClaim[]
    entities DiligenceEntity[]
    contradictions DiligenceContradiction[]
    chunks DiligenceChunk[]
    questionAnswers DiligenceQuestionAnswer[]
    evidenceGaps DiligenceEvidenceGap[]
    openQuestions DiligenceOpenQuestion[]

    @@index([projectId, createdAt])
    @@index([userId, createdAt])
    @@index([status])
    @@index([status, priority])
    @@index([workflowRunId])
}

model DiligenceStageRun {
    id                 String               @id @default(cuid())
    jobId              String
    stage              DiligenceStageName
    status             DiligenceStageStatus @default(PENDING)
    attempts           Int                  @default(0)
    provider           ApiKeyProvider?
    model              String?
    tokenUsageTotal    Int                  @default(0)
    estimatedCostUsd   Float?
    inputArtifactCount Int                  @default(0)
    outputArtifactCount Int                 @default(0)
    outputJson         Json?
    errorMessage       String?
    startedAt          DateTime?
    completedAt        DateTime?
    createdAt          DateTime             @default(now())
    updatedAt          DateTime             @updatedAt

    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@unique([jobId, stage])
    @@index([jobId, status])
}

model DiligenceArtifact {
    id              String                  @id @default(cuid())
    projectId       String
    jobId           String
    userId          String
    stage           DiligenceStageName?
    type            DiligenceArtifactType
    storageProvider DiligenceStorageProvider
    storageKey      String
    mimeType        String?
    sizeBytes       Int?
    checksum        String?
    metadata        Json?
    createdAt       DateTime                @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId, type])
    @@index([jobId, stage])
    @@index([storageProvider])
}

model DiligenceChunk {
    id               String   @id @default(cuid())
    projectId        String
    jobId            String
    userId           String
    documentPathname String
    documentFilename String
    page             Int?
    chunkIndex       Int
    text             String
    hash             String
    tokenEstimate    Int      @default(0)
    createdAt        DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([jobId, documentPathname, chunkIndex])
    @@index([jobId])
    @@index([projectId])
}

model DiligenceEntity {
    id          String   @id @default(cuid())
    projectId   String
    jobId       String
    userId      String
    name        String
    kind        String
    confidence  Float?
    sourceCount Int      @default(0)
    chunkRefs   Json?
    metadata    Json?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId, kind])
    @@index([jobId])
}

model DiligenceClaim {
    id             String              @id @default(cuid())
    projectId      String
    jobId          String
    userId         String
    claimText      String
    status         DiligenceClaimStatus @default(INCONCLUSIVE)
    confidence     Float?
    sourceCount    Int                 @default(0)
    chunkRefs      Json?
    evidenceRefs   Json?
    contradictions Json?
    createdAt      DateTime            @default(now())
    updatedAt      DateTime            @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId, status])
    @@index([jobId])
}

model DiligenceFinding {
    id           String              @id @default(cuid())
    projectId    String
    jobId        String
    userId       String
    type         DiligenceFindingType
    title        String
    summary      String
    severity     String?
    confidence   Float?
    sourceCount  Int                 @default(0)
    chunkRefs    Json?
    evidenceRefs Json?
    metadata     Json?
    createdAt    DateTime            @default(now())
    updatedAt    DateTime            @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId, type])
    @@index([jobId])
}

model DiligenceContradiction {
    id           String   @id @default(cuid())
    projectId    String
    jobId        String
    userId       String
    statementA   String
    statementB   String
    severity     String?
    confidence   Float?
    chunkRefs    Json?
    evidenceRefs Json?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@index([jobId])
}

model DiligenceQuestionAnswer {
    id          String                @id @default(cuid())
    projectId   String
    jobId       String
    userId      String
    question    DiligenceCoreQuestion
    summary     String
    structured  Json
    confidence  Float?
    sourceCount Int                   @default(0)
    chunkRefs   Json?
    createdAt   DateTime              @default(now())
    updatedAt   DateTime              @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([jobId, question])
    @@index([projectId])
}

model DiligenceEvidenceGap {
    id              String                @id @default(cuid())
    projectId       String
    jobId           String
    userId          String
    question        DiligenceCoreQuestion
    title           String
    description     String
    severity        String
    suggestedSource String?
    createdAt       DateTime              @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([jobId])
    @@index([projectId, question])
}

model DiligenceOpenQuestion {
    id         String                @id @default(cuid())
    projectId  String
    jobId      String
    userId     String
    category   DiligenceCoreQuestion
    question   String
    rationale  String
    priority   String
    resolvedBy String?
    chunkRefs  Json?
    createdAt  DateTime              @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    job DiligenceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([jobId])
    @@index([projectId, category, priority])
}
